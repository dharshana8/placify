{
  "name": "placify-ai",
  "version": "1.0.0",
  "description": "Campus Placement Management System with AI-powered features",
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && mvn spring-boot:run",
    "install-all": "cd frontend && npm install && cd ../backend && mvn clean install",
    "build": "cd frontend && npm run build",
    "start": "cd backend && mvn spring-boot:run"
  },
  "keywords": [
    "placement",
    "campus",
    "management",
    "ai",
    "spring-boot",
    "react"
  ],
  "author": "Placify AI Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}